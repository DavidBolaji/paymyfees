    "@tanstack/react-query": "^5.59.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "ejs": "^4.0.1",
    "framer-motion": "^11.11.0",
    "googleapis": "^168.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "^15.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-phone-input-2": "^2.15.1",
    "recharts": "^3.6.0",
    "resend": "^6.8.0",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.10"
