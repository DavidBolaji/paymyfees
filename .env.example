# Environment Configuration
# Copy this file to .env and fill in your values

# Node Environment
NODE_ENV=development

# Database - PostgreSQL with Prisma Accelerate
# DATABASE_URL: Connection pooler URL (for queries) - Use Prisma Accelerate URL
# DIRECT_URL: Direct database URL (for migrations) - Use direct PostgreSQL connection
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_PRISMA_ACCELERATE_API_KEY"
DIRECT_URL="postgresql://user:password@host:5432/paymyfees?schema=public&sslmode=require"

# Alternative: If not using Prisma Accelerate, use direct PostgreSQL connection for both
# DATABASE_URL="postgresql://user:password@host:5432/paymyfees?schema=public&sslmode=require"
# DIRECT_URL="postgresql://user:password@host:5432/paymyfees?schema=public&sslmode=require"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key-min-32-characters"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Application
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT="3000"

# Google Sheets (Waitlist) - Optional
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_SHEET_ID=""

# Payment Gateway - Paystack - Optional
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# Payment Gateway - Flutterwave - Optional
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_PUBLIC_KEY=""

# BVN/NIN Verification - Optional
MONO_SECRET_KEY=""
SMILE_API_KEY=""
SMILE_PARTNER_ID=""

# Email Service - Optional
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@paymyfees.co"

# SMS Service - Optional
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# File Storage - AWS S3 - Optional
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"

# Monitoring - Optional
SENTRY_DSN=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
