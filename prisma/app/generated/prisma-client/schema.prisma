// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

// ============================================
// GENERATOR CONFIGURATION
// ============================================

generator client {
  provider        = "prisma-client-js"
  output          = "app/generated/prisma-client"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

// ============================================
// DATASOURCE CONFIGURATION - PostgreSQL
// ============================================

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Note: Prisma Accelerate requires two connection strings:
// - DATABASE_URL: Connection pooler URL (for queries)
// - DIRECT_URL: Direct database URL (for migrations)
// 
// Example format:
// DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"
// DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"

// ============================================
// ENUMS
// ============================================

enum UserRole {
  PARENT
  SCHOOL
  ADMIN
  TEACHER
  STUDENT
}

enum LoanStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  WALLET
  USSD
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  FAILED
  CANCELLED
}

enum DocumentType {
  BVN
  NIN
  PASSPORT
  DRIVERS_LICENSE
  VOTERS_CARD
  SALARY_SLIP
  BANK_STATEMENT
  SCHOOL_INVOICE
  SCHOOL_ID
  CAC_DOCUMENT
  OTHER
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
  REMINDER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  phone         String    @unique @db.VarChar(20)
  password      String    @db.VarChar(255)
  role          UserRole
  fullName      String    @db.VarChar(255)
  profileImage  String?   @db.VarChar(500)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLogin     DateTime? @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)

  // Relations
  parentProfile  ParentProfile?
  schoolProfile  SchoolProfile?
  loans          Loan[]
  transactions   Transaction[]
  wallet         Wallet?
  notifications  Notification[]
  supportTickets SupportTicket[]
  auditLogs      AuditLog[]
  payments       Payment[]
  documents      Document[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model ParentProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal Information
  dateOfBirth DateTime? @db.Date
  address     String?   @db.VarChar(500)
  city        String?   @db.VarChar(100)
  state       String?   @db.VarChar(100)
  country     String    @default("Nigeria") @db.VarChar(100)

  // Verification Information
  bvn         String? @unique @db.VarChar(11)
  nin         String? @unique @db.VarChar(11)
  bvnVerified Boolean @default(false)
  ninVerified Boolean @default(false)

  // Employment Information
  employmentStatus String?  @db.VarChar(100)
  employerName     String?  @db.VarChar(255)
  monthlyIncome    Decimal? @db.Decimal(15, 2)

  // Credit Information
  creditScore        Int?    @db.Integer
  totalLoans         Int     @default(0) @db.Integer
  activeLoans        Int     @default(0) @db.Integer
  completedLoans     Int     @default(0) @db.Integer
  defaultedLoans     Int     @default(0) @db.Integer
  totalBorrowed      Decimal @default(0) @db.Decimal(15, 2)
  totalRepaid        Decimal @default(0) @db.Decimal(15, 2)
  outstandingBalance Decimal @default(0) @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  children  Student[]
  documents Document[]

  @@index([bvn])
  @@index([nin])
  @@index([userId])
  @@map("parent_profiles")
}

model SchoolProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // School Information
  schoolName    String  @db.VarChar(255)
  schoolAddress String  @db.VarChar(500)
  city          String  @db.VarChar(100)
  state         String  @db.VarChar(100)
  country       String  @default("Nigeria") @db.VarChar(100)
  schoolEmail   String  @unique @db.VarChar(255)
  schoolPhone   String  @unique @db.VarChar(20)
  website       String? @db.VarChar(255)

  // Contact Person
  contactPersonName     String @db.VarChar(255)
  contactPersonPosition String @db.VarChar(100)
  contactPersonEmail    String @db.VarChar(255)
  contactPersonPhone    String @db.VarChar(20)

  // Bank Details
  bankName      String @db.VarChar(100)
  accountNumber String @db.VarChar(20)
  accountName   String @db.VarChar(255)

  // Verification
  isVerified Boolean   @default(false)
  verifiedAt DateTime? @db.Timestamptz(3)

  // Statistics
  totalStudents      Int     @default(0) @db.Integer
  totalDisbursements Decimal @default(0) @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  students             Student[]
  loans                Loan[]
  disbursements        Disbursement[]
  verificationRequests SchoolVerification[]
  documents            Document[]

  @@index([schoolEmail])
  @@index([schoolPhone])
  @@index([userId])
  @@index([isVerified])
  @@map("school_profiles")
}

model Student {
  id       String         @id @default(uuid()) @db.Uuid
  parentId String         @db.Uuid
  parent   ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  schoolId String?        @db.Uuid
  school   SchoolProfile? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  // Student Information
  fullName     String    @db.VarChar(255)
  dateOfBirth  DateTime? @db.Date
  studentClass String    @db.VarChar(50)
  studentId    String?   @db.VarChar(50)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  loans Loan[]

  @@index([parentId])
  @@index([schoolId])
  @@map("students")
}

// ============================================
// LOAN MANAGEMENT
// ============================================

model Loan {
  id         String        @id @default(uuid()) @db.Uuid
  loanNumber String        @unique @db.VarChar(50)
  userId     String        @db.Uuid
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId  String        @db.Uuid
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId   String        @db.Uuid
  school     SchoolProfile @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Loan Details
  loanAmount      Decimal @db.Decimal(15, 2)
  interestRate    Decimal @db.Decimal(5, 2)
  totalInterest   Decimal @db.Decimal(15, 2)
  totalAmount     Decimal @db.Decimal(15, 2)
  monthlyPayment  Decimal @db.Decimal(15, 2)
  repaymentMonths Int     @db.Integer

  // School Details
  schoolName      String @db.VarChar(255)
  academicSession String @db.VarChar(50)
  term            String @db.VarChar(50)

  // Status
  status LoanStatus @default(PENDING)

  // Amounts
  amountDisbursed    Decimal @default(0) @db.Decimal(15, 2)
  amountRepaid       Decimal @default(0) @db.Decimal(15, 2)
  outstandingBalance Decimal @db.Decimal(15, 2)

  // Dates
  applicationDate  DateTime  @default(now()) @db.Timestamptz(3)
  approvalDate     DateTime? @db.Timestamptz(3)
  disbursementDate DateTime? @db.Timestamptz(3)
  firstPaymentDate DateTime? @db.Timestamptz(3)
  lastPaymentDate  DateTime? @db.Timestamptz(3)
  completionDate   DateTime? @db.Timestamptz(3)

  // Metadata
  approvedBy      String? @db.Uuid
  rejectionReason String? @db.Text
  notes           String? @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  installments  Installment[]
  payments      Payment[]
  disbursement  Disbursement?
  verification  SchoolVerification?
  documents     Document[]
  statusHistory LoanStatusHistory[]

  @@index([userId])
  @@index([studentId])
  @@index([schoolId])
  @@index([status])
  @@index([loanNumber])
  @@index([applicationDate])
  @@map("loans")
}

model Installment {
  id     String @id @default(uuid()) @db.Uuid
  loanId String @db.Uuid
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  installmentNumber Int           @db.Integer
  amount            Decimal       @db.Decimal(15, 2)
  dueDate           DateTime      @db.Timestamptz(3)
  paidDate          DateTime?     @db.Timestamptz(3)
  status            PaymentStatus @default(PENDING)

  // Overdue tracking
  daysOverdue Int     @default(0) @db.Integer
  lateFee     Decimal @default(0) @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  payments Payment[]

  @@unique([loanId, installmentNumber])
  @@index([loanId])
  @@index([status])
  @@index([dueDate])
  @@map("installments")
}

model Payment {
  id               String       @id @default(uuid()) @db.Uuid
  paymentReference String       @unique @db.VarChar(100)
  loanId           String       @db.Uuid
  loan             Loan         @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installmentId    String?      @db.Uuid
  installment      Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  userId           String       @db.Uuid
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount        Decimal           @db.Decimal(15, 2)
  paymentMethod PaymentMethod
  status        TransactionStatus @default(PENDING)

  // Payment Gateway Details
  gatewayReference String? @db.VarChar(255)
  gatewayResponse  String? @db.Text

  paymentDate DateTime  @default(now()) @db.Timestamptz(3)
  confirmedAt DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  transaction Transaction?

  @@index([loanId])
  @@index([userId])
  @@index([status])
  @@index([paymentReference])
  @@index([paymentDate])
  @@map("payments")
}

model Disbursement {
  id                    String        @id @default(uuid()) @db.Uuid
  disbursementReference String        @unique @db.VarChar(100)
  loanId                String        @unique @db.Uuid
  loan                  Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  schoolId              String        @db.Uuid
  school                SchoolProfile @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  amount Decimal           @db.Decimal(15, 2)
  status TransactionStatus @default(PENDING)

  // Bank Details
  bankName      String @db.VarChar(100)
  accountNumber String @db.VarChar(20)
  accountName   String @db.VarChar(255)

  // Transfer Details
  transferReference String? @db.VarChar(255)
  transferResponse  String? @db.Text

  disbursedAt DateTime? @db.Timestamptz(3)
  confirmedAt DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([loanId])
  @@index([schoolId])
  @@index([status])
  @@map("disbursements")
}

model LoanStatusHistory {
  id     String @id @default(uuid()) @db.Uuid
  loanId String @db.Uuid
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  previousStatus LoanStatus?
  newStatus      LoanStatus
  changedBy      String?     @db.Uuid
  reason         String?     @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([loanId])
  @@index([createdAt])
  @@map("loan_status_history")
}

// ============================================
// VERIFICATION
// ============================================

model SchoolVerification {
  id       String        @id @default(uuid()) @db.Uuid
  loanId   String        @unique @db.Uuid
  loan     Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  schoolId String        @db.Uuid
  school   SchoolProfile @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Verification Details
  studentName   String  @db.VarChar(255)
  studentClass  String  @db.VarChar(50)
  invoiceAmount Decimal @db.Decimal(15, 2)

  // School Response
  status              VerificationStatus @default(PENDING)
  enrollmentConfirmed Boolean            @default(false)
  invoiceConfirmed    Boolean            @default(false)
  actualInvoiceAmount Decimal?           @db.Decimal(15, 2)

  // Metadata
  requestedAt DateTime  @default(now()) @db.Timestamptz(3)
  respondedAt DateTime? @db.Timestamptz(3)
  verifiedBy  String?   @db.Uuid
  notes       String?   @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([loanId])
  @@index([schoolId])
  @@index([status])
  @@map("school_verifications")
}

model Document {
  id       String         @id @default(uuid()) @db.Uuid
  userId   String?        @db.Uuid
  user     User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId String?        @db.Uuid
  parent   ParentProfile? @relation(fields: [parentId], references: [id], onDelete: Cascade)
  schoolId String?        @db.Uuid
  school   SchoolProfile? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  loanId   String?        @db.Uuid
  loan     Loan?          @relation(fields: [loanId], references: [id], onDelete: Cascade)

  documentType DocumentType
  fileName     String       @db.VarChar(255)
  fileUrl      String       @db.VarChar(500)
  fileSize     Int          @db.Integer
  mimeType     String       @db.VarChar(100)

  isVerified Boolean   @default(false)
  verifiedAt DateTime? @db.Timestamptz(3)
  verifiedBy String?   @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([parentId])
  @@index([schoolId])
  @@index([loanId])
  @@index([documentType])
  @@map("documents")
}

// ============================================
// WALLET & TRANSACTIONS
// ============================================

model Wallet {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance  Decimal @default(0) @db.Decimal(15, 2)
  currency String  @default("NGN") @db.VarChar(3)

  // Limits
  dailyLimit   Decimal? @db.Decimal(15, 2)
  monthlyLimit Decimal? @db.Decimal(15, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  transactions Transaction[]

  @@index([userId])
  @@map("wallets")
}

model Transaction {
  id                   String   @id @default(uuid()) @db.Uuid
  transactionReference String   @unique @db.VarChar(100)
  userId               String   @db.Uuid
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId             String?  @db.Uuid
  wallet               Wallet?  @relation(fields: [walletId], references: [id], onDelete: SetNull)
  paymentId            String?  @unique @db.Uuid
  payment              Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  balanceBefore Decimal         @db.Decimal(15, 2)
  balanceAfter  Decimal         @db.Decimal(15, 2)

  description   String            @db.VarChar(500)
  category      String?           @db.VarChar(100)
  paymentMethod PaymentMethod?
  status        TransactionStatus @default(PENDING)

  // Gateway Details
  gatewayReference String? @db.VarChar(255)
  gatewayResponse  String? @db.Text

  metadata Json? @db.JsonB

  transactionDate DateTime @default(now()) @db.Timestamptz(3)
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([transactionReference])
  @@index([transactionDate])
  @@map("transactions")
}

// ============================================
// NOTIFICATIONS & COMMUNICATION
// ============================================

model Notification {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String           @db.VarChar(255)
  message String           @db.Text

  isRead Boolean   @default(false)
  readAt DateTime? @db.Timestamptz(3)

  // Metadata
  actionUrl String? @db.VarChar(500)
  metadata  Json?   @db.JsonB

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model EmailLog {
  id             String  @id @default(uuid()) @db.Uuid
  recipientEmail String  @db.VarChar(255)
  recipientName  String? @db.VarChar(255)
  subject        String  @db.VarChar(500)
  body           String  @db.Text

  status       String    @default("pending") @db.VarChar(50)
  sentAt       DateTime? @db.Timestamptz(3)
  failedAt     DateTime? @db.Timestamptz(3)
  errorMessage String?   @db.Text

  // Metadata
  emailType String @db.VarChar(100)
  metadata  Json?  @db.JsonB

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([recipientEmail])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

model SmsLog {
  id             String @id @default(uuid()) @db.Uuid
  recipientPhone String @db.VarChar(20)
  message        String @db.Text

  status       String    @default("pending") @db.VarChar(50)
  sentAt       DateTime? @db.Timestamptz(3)
  failedAt     DateTime? @db.Timestamptz(3)
  errorMessage String?   @db.Text

  // Gateway Details
  gatewayReference String? @db.VarChar(255)
  gatewayResponse  String? @db.Text

  // Metadata
  smsType  String @db.VarChar(100)
  metadata Json?  @db.JsonB

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([recipientPhone])
  @@index([status])
  @@index([createdAt])
  @@map("sms_logs")
}

// ============================================
// SUPPORT & HELP
// ============================================

model SupportTicket {
  id           String @id @default(uuid()) @db.Uuid
  ticketNumber String @unique @db.VarChar(50)
  userId       String @db.Uuid
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject  String                @db.VarChar(500)
  category String                @db.VarChar(100)
  priority SupportTicketPriority @default(MEDIUM)
  status   SupportTicketStatus   @default(OPEN)

  description String @db.Text

  assignedTo String?   @db.Uuid
  resolvedAt DateTime? @db.Timestamptz(3)
  closedAt   DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Relations
  messages    SupportMessage[]
  attachments SupportAttachment[]

  @@index([userId])
  @@index([status])
  @@index([ticketNumber])
  @@map("support_tickets")
}

model SupportMessage {
  id       String        @id @default(uuid()) @db.Uuid
  ticketId String        @db.Uuid
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId   String   @db.Uuid
  senderRole UserRole
  message    String   @db.Text

  isInternal Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([ticketId])
  @@map("support_messages")
}

model SupportAttachment {
  id       String        @id @default(uuid()) @db.Uuid
  ticketId String        @db.Uuid
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  fileName String @db.VarChar(255)
  fileUrl  String @db.VarChar(500)
  fileSize Int    @db.Integer
  mimeType String @db.VarChar(100)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([ticketId])
  @@map("support_attachments")
}

model Faq {
  id       String  @id @default(uuid()) @db.Uuid
  question String  @db.VarChar(500)
  answer   String  @db.Text
  category String  @db.VarChar(100)
  order    Int     @default(0) @db.Integer
  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([category])
  @@index([isActive])
  @@map("faqs")
}

// ============================================
// WAITLIST & EARLY ACCESS
// ============================================

model Waitlist {
  id          String @id @default(uuid()) @db.Uuid
  role        String @db.VarChar(50)
  fullName    String @db.VarChar(255)
  email       String @unique @db.VarChar(255)
  phone       String @db.VarChar(20)
  institution String @db.VarChar(255)
  loanAmount  String @db.VarChar(50)

  status       String    @default("pending") @db.VarChar(50)
  invitedAt    DateTime? @db.Timestamptz(3)
  registeredAt DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([email])
  @@index([status])
  @@map("waitlist")
}

// ============================================
// SYSTEM & AUDIT
// ============================================

model AuditLog {
  id     String  @id @default(uuid()) @db.Uuid
  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String  @db.VarChar(100)
  entity   String  @db.VarChar(100)
  entityId String? @db.Uuid

  oldValues Json? @db.JsonB
  newValues Json? @db.JsonB

  ipAddress String? @db.VarChar(45)
  userAgent String? @db.VarChar(500)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique @db.VarChar(100)
  value       String  @db.Text
  description String? @db.VarChar(500)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([key])
  @@map("system_settings")
}

model PaymentReminder {
  id            String @id @default(uuid()) @db.Uuid
  installmentId String @db.Uuid
  reminderType  String @db.VarChar(50) // "7_days", "3_days", "1_day", "overdue"

  sentAt DateTime? @db.Timestamptz(3)
  status String    @default("pending") @db.VarChar(50)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([installmentId])
  @@index([status])
  @@map("payment_reminders")
}
