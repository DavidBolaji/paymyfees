generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid()) @db.Char(36)
  email                String                @unique @db.VarChar(255)
  phone                String?               @unique @db.VarChar(20)
  password             String?               @db.VarChar(255)
  role                 UserRole
  fullName             String                @db.VarChar(255)
  firstName            String?               @db.VarChar(100)
  lastName             String?               @db.VarChar(100)
  middleName           String?               @db.VarChar(100)
  dob                  DateTime?             @db.Date
  address              String?               @db.VarChar(500)
  city                 String?               @db.VarChar(100)
  // NIN and BVN are NOT stored raw — they are passed through to Embedly for
  // verification only, then discarded. Only the verified status is persisted.
  // This is required for compliance with the Nigeria Data Protection Act 2023
  // and CBN KYC guidelines (biometric data minimisation principle).
  ninVerified          Boolean               @default(false)
  bvnVerified          Boolean               @default(false)
  kycVerifiedAt        DateTime?
  bankCode             String?               @db.VarChar(20)
  bankAccountNumber    String?               @db.VarChar(20)
  bankAccountName      String?               @db.VarChar(255)
  profileImage         String?               @db.VarChar(500)
  emailVerified        Boolean               @default(false)
  phoneVerified        Boolean               @default(false)
  isActive             Boolean               @default(true)
  isFirstTime          Boolean               @default(true)
  twoFactorEnabled          Boolean               @default(false)
  twoFactorSecret           String?               @db.VarChar(255)
  lastLogin                 DateTime?
  embedlyCustomerId         String?               @db.VarChar(255)
  googleId                  String?               @unique @db.VarChar(255)
  googleProfileComplete     Boolean               @default(false)
  loanEligibilitySuspended  Boolean               @default(false)
  frozenUntil               DateTime?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  country                   String                @db.VarChar(255)
  residencyStatus           ResidencyStatus       @default(LOCAL)
  gender                    Gender?
  auditLogs            AuditLog[]
  documents            Document[]
  loans                Loan[]
  notificationSettings NotificationSettings?
  notifications        Notification[]
  parentProfile        ParentProfile?
  studentProfiles      StudentProfile[]
  teacherProfile       TeacherProfile?
  payments             Payment[]
  schoolProfile        SchoolProfile[]
  supportTickets       SupportTicket[]
  transactions         Transaction[]
  verificationTokens   VerificationToken[]
  wallet               Wallet?

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([googleId])
  @@index([createdAt])
  @@map("users")
}

model ParentProfile {
  id                 String     @id @default(uuid()) @db.Char(36)
  userId             String     @unique @db.Char(36)
  dateOfBirth        DateTime?  @db.Date
  address            String?    @db.VarChar(500)
  city               String?    @db.VarChar(100)
  state              String?    @db.VarChar(100)
  postalCode         String?    @db.VarChar(20)
  country            String     @default("Nigeria") @db.VarChar(100)
  language           String?    @db.VarChar(50)
  bvn                String?    @unique @db.VarChar(11)
  nin                String?    @unique @db.VarChar(11)
  bvnVerified        Boolean    @default(false)
  ninVerified        Boolean    @default(false)
  employmentStatus   String?    @db.VarChar(100)
  employerName       String?    @db.VarChar(255)
  employmentRole     String?    @db.VarChar(255)
  employmentType     String?    @db.VarChar(50)
  lengthOfEmployment String?    @db.VarChar(50)
  monthlyIncome      Decimal?   @db.Decimal(15, 2)
  creditScore        Int?
  totalLoans         Int        @default(0)
  activeLoans        Int        @default(0)
  completedLoans     Int        @default(0)
  defaultedLoans     Int        @default(0)
  totalBorrowed      Decimal    @default(0.00) @db.Decimal(15, 2)
  totalRepaid        Decimal    @default(0.00) @db.Decimal(15, 2)
  outstandingBalance Decimal    @default(0.00) @db.Decimal(15, 2)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  documents          Document[]
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bvn])
  @@index([nin])
  @@index([userId])
  @@map("parent_profiles")
}

model StudentProfile {
  id           String    @id @default(uuid()) @db.Char(36)
  parentId     String    @db.Char(36)
  studentName  String    @db.VarChar(255)
  dateOfBirth  DateTime? @db.Date
  relationship String    @db.VarChar(100)
  classLevel   String    @db.VarChar(100)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  parent       User      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  loans        Loan[]

  @@index([parentId])
  @@map("student_profiles")
}

model TeacherProfile {
  id               String    @id @default(uuid()) @db.Char(36)
  userId           String    @unique @db.Char(36)
  schoolName       String?   @db.VarChar(255)
  schoolEmail      String?   @db.VarChar(255)
  schoolAddress    String?   @db.VarChar(500)
  registrationNumber String? @db.VarChar(100)
  subject          String?   @db.VarChar(255)
  employmentStatus String?   @db.VarChar(100)
  staffId          String?   @db.VarChar(100)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("teacher_profiles")
}

model SchoolProfile {
  id                     String                      @id @default(uuid()) @db.Char(36)
  userId                 String                      @db.Char(36)
  isPrimary              Boolean                     @default(false)
  schoolName             String                      @db.VarChar(255)
  schoolAddress          String?                     @db.VarChar(500)
  city                   String?                     @db.VarChar(100)
  state                  String?                     @db.VarChar(100)
  country                String?                     @default("Nigeria") @db.VarChar(100)
  schoolEmail            String?                     @db.VarChar(255)
  schoolPhone            String?                     @db.VarChar(20)
  website                String?                     @db.VarChar(255)
  schoolType             String?                     @db.VarChar(100)
  yearEstablished        Int?
  registrationNumber     String?                     @db.VarChar(100)
  contactPersonName      String?                     @db.VarChar(255)
  contactPersonPosition  String?                     @db.VarChar(100)
  contactPersonEmail     String?                     @db.VarChar(255)
  contactPersonPhone     String?                     @db.VarChar(20)
  bankName               String?                     @db.VarChar(100)
  accountNumber          String?                     @db.VarChar(20)
  accountName            String?                     @db.VarChar(255)
  academicLevel          String?                     @db.VarChar(100)
  currentAcademicSession String?                     @db.VarChar(50)
  notes                  String?
  isVerified             Boolean                     @default(false)
  verifiedAt             DateTime?
  totalStudents          Int                         @default(0)
  totalDisbursements     Decimal                     @default(0.00) @db.Decimal(15, 2)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  disbursements          Disbursement[]
  documents              Document[]
  loans                  Loan[]
  profileVerifications   SchoolProfileVerification[]
  user                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationRequests   SchoolVerification[]

  @@index([schoolEmail])
  @@index([schoolPhone])
  @@index([userId])
  @@index([isVerified])
  @@map("school_profiles")
}

model Loan {
  id                   String                @id @default(uuid()) @db.Char(36)
  loanNumber           String                @unique @db.VarChar(50)
  userId               String                @db.Char(36)
  schoolId             String                @db.Char(36)
  studentProfileId     String?               @db.Char(36)
  loanAmount           Decimal               @db.Decimal(15, 2)
  interestRate         Decimal               @db.Decimal(5, 2)
  totalInterest        Decimal               @db.Decimal(15, 2)
  totalAmount          Decimal               @db.Decimal(15, 2)
  monthlyPayment       Decimal               @db.Decimal(15, 2)
  repaymentMonths      Int
  schoolName           String                @db.VarChar(255)
  academicSession      String                @db.VarChar(50)
  term                 String?               @db.VarChar(50)
  residencyStatus      ResidencyStatus       @default(LOCAL)
  countryOfStudy       String?               @db.VarChar(100)
  programCourseOfStudy String?               @db.VarChar(255)
  employmentStatus     String?               @db.VarChar(100)
  companyName          String?               @db.VarChar(255)
  jobTitleRole         String?               @db.VarChar(255)
  monthlyNetIncome     Decimal?              @db.Decimal(15, 2)
  paymentFrequency     String?               @db.VarChar(50)
  accountHolderName    String?               @db.VarChar(255)
  bankName             String?               @db.VarChar(100)
  accountNumber        String?               @db.VarChar(50)
  countryOfBankAccount String?               @db.VarChar(100)
  status               LoanStatus            @default(PENDING)
  amountDisbursed      Decimal               @default(0.00) @db.Decimal(15, 2)
  amountRepaid         Decimal               @default(0.00) @db.Decimal(15, 2)
  outstandingBalance   Decimal               @db.Decimal(15, 2)
  applicationDate      DateTime              @default(now())
  approvalDate         DateTime?
  disbursementDate     DateTime?
  firstPaymentDate     DateTime?
  lastPaymentDate      DateTime?
  completionDate       DateTime?
  approvedBy           String?               @db.Char(36)
  rejectionReason      String?
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  disbursement         Disbursement?
  documents            Document[]
  installments         Installment[]
  statusHistory        LoanStatusHistory[]
  school               SchoolProfile         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile       StudentProfile?       @relation(fields: [studentProfileId], references: [id])
  payments             Payment[]
  fundingDetails       SchoolFundingDetails?
  verification         SchoolVerification?

  @@index([userId])
  @@index([schoolId])
  @@index([studentProfileId])
  @@index([status])
  @@index([loanNumber])
  @@index([applicationDate])
  @@index([residencyStatus])
  @@map("loans")
}

model Installment {
  id                String        @id @default(uuid()) @db.Char(36)
  loanId            String        @db.Char(36)
  installmentNumber Int
  amount            Decimal       @db.Decimal(15, 2)
  dueDate           DateTime
  paidDate          DateTime?
  status            PaymentStatus @default(PENDING)
  daysOverdue       Int           @default(0)
  lateFee           Decimal       @default(0.00) @db.Decimal(15, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  loan              Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@unique([loanId, installmentNumber])
  @@index([loanId])
  @@index([status])
  @@index([dueDate])
  @@map("installments")
}

model Payment {
  id               String            @id @default(uuid()) @db.Char(36)
  paymentReference String            @unique @db.VarChar(100)
  loanId           String            @db.Char(36)
  installmentId    String?           @db.Char(36)
  userId           String            @db.Char(36)
  amount           Decimal           @db.Decimal(15, 2)
  paymentMethod    PaymentMethod
  status           TransactionStatus @default(PENDING)
  gatewayReference String?           @db.VarChar(255)
  gatewayResponse  String?
  paymentDate      DateTime          @default(now())
  confirmedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  installment      Installment?      @relation(fields: [installmentId], references: [id])
  loan             Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction      Transaction?

  @@index([loanId])
  @@index([userId])
  @@index([status])
  @@index([paymentReference])
  @@index([paymentDate])
  @@index([installmentId], map: "payments_installmentId_fkey")
  @@map("payments")
}

model Disbursement {
  id                    String            @id @default(uuid()) @db.Char(36)
  disbursementReference String            @unique @db.VarChar(100)
  loanId                String            @unique @db.Char(36)
  schoolId              String            @db.Char(36)
  amount                Decimal           @db.Decimal(15, 2)
  status                TransactionStatus @default(PENDING)
  bankName              String            @db.VarChar(100)
  accountNumber         String            @db.VarChar(20)
  accountName           String            @db.VarChar(255)
  transferReference     String?           @db.VarChar(255)
  transferResponse      String?
  disbursedAt           DateTime?
  confirmedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  loan                  Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  school                SchoolProfile     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([schoolId])
  @@index([status])
  @@map("disbursements")
}

model SchoolFundingDetails {
  id                       String   @id @default(uuid()) @db.Char(36)
  loanId                   String   @unique @db.Char(36)
  totalTermlyRevenue       Decimal? @db.Decimal(15, 2)
  numberOfTeachers         Int?
  existingDebts            Decimal? @db.Decimal(15, 2)
  otherIncomeSources       String?  @db.VarChar(100)
  schoolEmail              String?  @db.VarChar(255)
  schoolRegistrationNumber String?  @db.VarChar(100)
  schoolAddress            String?  @db.VarChar(500)
  totalNumberOfStudents    Int?
  academicLevelsOffered    String?  @db.VarChar(100)
  numberOfNonTeachingStaff String?  @db.VarChar(50)
  consentSchoolDetails     Boolean  @default(false)
  consentDirectPayment     Boolean  @default(false)
  consentTerms             Boolean  @default(false)
  consentTimestamp         DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  loan                     Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("school_funding_details")
}

model LoanStatusHistory {
  id             String      @id @default(uuid()) @db.Char(36)
  loanId         String      @db.Char(36)
  previousStatus LoanStatus?
  newStatus      LoanStatus
  changedBy      String?     @db.Char(36)
  reason         String?
  createdAt      DateTime    @default(now())
  loan           Loan        @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([createdAt])
  @@map("loan_status_history")
}

model SchoolProfileVerification {
  id          String                         @id @default(uuid()) @db.Char(36)
  schoolId    String                         @db.Char(36)
  userId      String                         @db.Char(36)
  status      VerificationStatus             @default(PENDING)
  submittedAt DateTime                       @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?                        @db.Char(36)
  notes       String?
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt
  logs        SchoolProfileVerificationLog[]
  school      SchoolProfile                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([userId])
  @@index([status])
  @@map("school_profile_verifications")
}

model SchoolProfileVerificationLog {
  id             String                    @id @default(uuid()) @db.Char(36)
  verificationId String                    @db.Char(36)
  schoolId       String                    @db.Char(36)
  activity       String                    @db.VarChar(255)
  details        String?
  status         VerificationStatus
  performedBy    String?                   @db.Char(36)
  createdAt      DateTime                  @default(now())
  verification   SchoolProfileVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("school_profile_verification_logs")
}

model VerificationLog {
  id             String             @id @default(uuid()) @db.Char(36)
  verificationId String             @db.Char(36)
  schoolId       String             @db.Char(36)
  activity       String             @db.VarChar(255)
  details        String?
  status         VerificationStatus
  performedBy    String?            @db.Char(36)
  createdAt      DateTime           @default(now())
  verification   SchoolVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("verification_logs")
}

model SchoolVerification {
  id                  String             @id @default(uuid()) @db.Char(36)
  loanId              String             @unique @db.Char(36)
  schoolId            String             @db.Char(36)
  studentName         String             @db.VarChar(255)
  studentClass        String             @db.VarChar(50)
  invoiceAmount       Decimal            @db.Decimal(15, 2)
  status              VerificationStatus @default(PENDING)
  enrollmentConfirmed Boolean            @default(false)
  invoiceConfirmed    Boolean            @default(false)
  actualInvoiceAmount Decimal?           @db.Decimal(15, 2)
  requestedAt         DateTime           @default(now())
  respondedAt         DateTime?
  verifiedBy          String?            @db.Char(36)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  loan                Loan               @relation(fields: [loanId], references: [id], onDelete: Cascade)
  school              SchoolProfile      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  logs                VerificationLog[]

  @@index([loanId])
  @@index([schoolId])
  @@index([status])
  @@map("school_verifications")
}

model Document {
  id           String         @id @default(uuid()) @db.Char(36)
  userId       String?        @db.Char(36)
  parentId     String?        @db.Char(36)
  schoolId     String?        @db.Char(36)
  loanId       String?        @db.Char(36)
  documentType DocumentType
  fileName     String         @db.VarChar(255)
  fileUrl      String         @db.VarChar(500)
  fileSize     Int
  mimeType     String         @db.VarChar(100)
  isVerified   Boolean        @default(false)
  verifiedAt   DateTime?
  verifiedBy   String?        @db.Char(36)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  loan         Loan?          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  parent       ParentProfile? @relation(fields: [parentId], references: [id], onDelete: Cascade)
  school       SchoolProfile? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentId])
  @@index([schoolId])
  @@index([loanId])
  @@index([documentType])
  @@map("documents")
}

model Wallet {
  id                   String        @id @default(uuid()) @db.Char(36)
  userId               String        @unique @db.Char(36)
  balance              Decimal       @default(0.00) @db.Decimal(15, 2)
  currency             String        @default("NGN") @db.VarChar(3)
  dailyLimit           Decimal?      @db.Decimal(15, 2)
  monthlyLimit         Decimal?      @db.Decimal(15, 2)
  autoDebitEnabled     Boolean       @default(false)
  isActive             Boolean       @default(true)
  embedlyWalletId      String?       @db.VarChar(255)
  virtualAccountNumber String?       @db.VarChar(20)
  virtualAccountBank   String?       @db.VarChar(100)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  transactions     Transaction[]
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

model Transaction {
  id                   String            @id @default(uuid()) @db.Char(36)
  transactionReference String            @unique @db.VarChar(100)
  userId               String            @db.Char(36)
  walletId             String?           @db.Char(36)
  paymentId            String?           @unique @db.Char(36)
  type                 TransactionType
  amount               Decimal           @db.Decimal(15, 2)
  balanceBefore        Decimal           @db.Decimal(15, 2)
  balanceAfter         Decimal           @db.Decimal(15, 2)
  description          String            @db.VarChar(500)
  category             String?           @db.VarChar(100)
  paymentMethod        PaymentMethod?
  status               TransactionStatus @default(PENDING)
  gatewayReference     String?           @db.VarChar(255)
  gatewayResponse      String?
  metadata             Json?
  transactionDate      DateTime          @default(now())
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  payment              Payment?          @relation(fields: [paymentId], references: [id])
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet               Wallet?           @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([transactionReference])
  @@index([transactionDate])
  @@map("transactions")
}

model Notification {
  id        String           @id @default(uuid()) @db.Char(36)
  userId    String           @db.Char(36)
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  actionUrl String?          @db.VarChar(500)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model EmailLog {
  id             String    @id @default(uuid()) @db.Char(36)
  recipientEmail String    @db.VarChar(255)
  recipientName  String?   @db.VarChar(255)
  subject        String    @db.VarChar(500)
  body           String
  status         String    @default("pending") @db.VarChar(50)
  sentAt         DateTime?
  failedAt       DateTime?
  errorMessage   String?
  emailType      String    @db.VarChar(100)
  metadata       Json?
  createdAt      DateTime  @default(now())

  @@index([recipientEmail])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

model SmsLog {
  id               String    @id @default(uuid()) @db.Char(36)
  recipientPhone   String    @db.VarChar(20)
  message          String
  status           String    @default("pending") @db.VarChar(50)
  sentAt           DateTime?
  failedAt         DateTime?
  errorMessage     String?
  gatewayReference String?   @db.VarChar(255)
  gatewayResponse  String?
  smsType          String    @db.VarChar(100)
  metadata         Json?
  createdAt        DateTime  @default(now())

  @@index([recipientPhone])
  @@index([status])
  @@index([createdAt])
  @@map("sms_logs")
}

model SupportTicket {
  id                String                @id @default(uuid()) @db.Char(36)
  ticketNumber      String                @unique @db.VarChar(50)
  userId            String                @db.Char(36)
  subject           String                @db.VarChar(500)
  category          String                @db.VarChar(100)
  channel           String                @default("In-App") @db.VarChar(50)
  priority          SupportTicketPriority @default(MEDIUM)
  status            SupportTicketStatus   @default(OPEN)
  description       String
  assignedTo        String?               @db.Char(36)
  firstResponseAt   DateTime?
  resolvedAt        DateTime?
  closedAt          DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  attachments       SupportAttachment[]
  messages          SupportMessage[]
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([ticketNumber])
  @@map("support_tickets")
}

model SupportMessage {
  id         String        @id @default(uuid()) @db.Char(36)
  ticketId   String        @db.Char(36)
  senderId   String        @db.Char(36)
  senderRole UserRole
  message    String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}

model SupportAttachment {
  id        String        @id @default(uuid()) @db.Char(36)
  ticketId  String        @db.Char(36)
  fileName  String        @db.VarChar(255)
  fileUrl   String        @db.VarChar(500)
  fileSize  Int
  mimeType  String        @db.VarChar(100)
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_attachments")
}

model Faq {
  id        String   @id @default(uuid()) @db.Char(36)
  question  String   @db.VarChar(500)
  answer    String
  category  String   @db.VarChar(100)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("faqs")
}

model Waitlist {
  id           String    @id @default(uuid()) @db.Char(36)
  role         String    @db.VarChar(50)
  fullName     String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  phone        String    @db.VarChar(20)
  institution  String    @db.VarChar(255)
  loanAmount   String    @db.VarChar(50)
  status       String    @default("pending") @db.VarChar(50)
  invitedAt    DateTime?
  registeredAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@map("waitlist")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String?  @db.Char(36)
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @db.Char(36)
  oldValues Json?
  newValues Json?
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id          String   @id @default(uuid()) @db.Char(36)
  key         String   @unique @db.VarChar(100)
  value       String
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("system_settings")
}

model PaymentReminder {
  id            String    @id @default(uuid()) @db.Char(36)
  installmentId String    @db.Char(36)
  reminderType  String    @db.VarChar(50)
  sentAt        DateTime?
  status        String    @default("pending") @db.VarChar(50)
  createdAt     DateTime  @default(now())

  @@index([installmentId])
  @@index([status])
  @@map("payment_reminders")
}

model VerificationToken {
  id        String           @id @default(uuid()) @db.Char(36)
  userId    String           @db.Char(36)
  token     String           @unique @db.VarChar(255)
  type      VerificationType
  expiresAt DateTime
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model SchoolSupportMessage {
  id        String    @id @default(uuid()) @db.Char(36)
  schoolId  String    @db.Char(36)
  message   String
  priority  String    @default("normal") @db.VarChar(50)
  isRead    Boolean   @default(false)
  readAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([schoolId])
  @@index([isRead])
  @@index([createdAt])
  @@map("school_support_messages")
}

model NotificationSettings {
  id                 String   @id @default(uuid()) @db.Char(36)
  userId             String   @unique @db.Char(36)
  emailNotifications Boolean  @default(true)
  inAppNotifications Boolean  @default(true)
  walletFunding      Boolean  @default(true)
  loanApproval       Boolean  @default(true)
  repaymentReminders Boolean  @default(true)
  verificationStatus Boolean  @default(true)
  securityAlerts     Boolean  @default(true)
  promotions         Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_settings")
}

model SavedPaymentMethod {
  id                String   @id @default(uuid()) @db.Char(36)
  userId            String   @db.Char(36)
  authorizationCode String   @db.VarChar(255)
  cardType          String   @db.VarChar(50)
  last4             String   @db.VarChar(4)
  expMonth          String   @db.VarChar(2)
  expYear           String   @db.VarChar(4)
  bank              String?  @db.VarChar(100)
  brand             String   @db.VarChar(50)
  isDefault         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([authorizationCode])
  @@map("saved_payment_methods")
}

