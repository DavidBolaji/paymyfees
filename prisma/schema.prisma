model Loan {
  id                 String              @id @default(uuid()) @db.Uuid
  loanNumber         String              @unique @db.VarChar(50)
  userId             String              @db.Uuid
  // studentId          String              @db.Uuid
  schoolId           String              @db.Uuid
  loanAmount         Decimal             @db.Decimal(15, 2)
  interestRate       Decimal             @db.Decimal(5, 2)
  totalInterest      Decimal             @db.Decimal(15, 2)
  totalAmount        Decimal             @db.Decimal(15, 2)
  monthlyPayment     Decimal             @db.Decimal(15, 2)
  repaymentMonths    Int
  schoolName         String              @db.VarChar(255)
  academicSession    String              @db.VarChar(50)
  term               String?             @db.VarChar(50)
  residencyStatus    ResidencyStatus     @default(LOCAL)
  
  // International student specific fields
  countryOfStudy         String?         @db.VarChar(100)
  programCourseOfStudy   String?         @db.VarChar(255)
  employmentStatus       String?         @db.VarChar(100)
  companyName            String?         @db.VarChar(255)
  jobTitleRole           String?         @db.VarChar(255)
  monthlyNetIncome       Decimal?        @db.Decimal(15, 2)
  paymentFrequency       String?         @db.VarChar(50)
  accountHolderName      String?         @db.VarChar(255)
  bankName               String?         @db.VarChar(100)
  accountNumber          String?         @db.VarChar(50)
  countryOfBankAccount   String?         @db.VarChar(100)
  
  status             LoanStatus          @default(PENDING)
  amountDisbursed    Decimal             @default(0) @db.Decimal(15, 2)
  amountRepaid       Decimal             @default(0) @db.Decimal(15, 2)
  outstandingBalance Decimal             @db.Decimal(15, 2)
  applicationDate    DateTime            @default(now()) @db.Timestamptz(3)
  approvalDate       DateTime?           @db.Timestamptz(3)
  disbursementDate   DateTime?           @db.Timestamptz(3)
  firstPaymentDate   DateTime?           @db.Timestamptz(3)
  lastPaymentDate    DateTime?           @db.Timestamptz(3)
  completionDate     DateTime?           @db.Timestamptz(3)
  approvedBy         String?             @db.Uuid
  rejectionReason    String?
  notes              String?
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)
  disbursement       Disbursement?
  documents          Document[]
  installments       Installment[]
  statusHistory      LoanStatusHistory[]
  school             SchoolProfile       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  // student            Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments           Payment[]
  verification       SchoolVerification?

  @@index([userId])
  // @@index([studentId])
  @@index([schoolId])
  @@index([status])
  @@index([loanNumber])
  @@index([applicationDate])
  @@index([residencyStatus])
  @@map("loans")
}
model Installment {
  id                String        @id @default(uuid()) @db.Uuid
  loanId            String        @db.Uuid
  installmentNumber Int
  amount            Decimal       @db.Decimal(15, 2)
  dueDate           DateTime      @db.Timestamptz(3)
  paidDate          DateTime?     @db.Timestamptz(3)
  status            PaymentStatus @default(PENDING)
  daysOverdue       Int           @default(0)
  lateFee           Decimal       @default(0) @db.Decimal(15, 2)
  createdAt         DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime      @updatedAt @db.Timestamptz(3)
  loan              Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@unique([loanId, installmentNumber])
  @@index([loanId])
  @@index([status])
  @@index([dueDate])
  @@map("installments")
}

model Payment {
  id               String            @id @default(uuid()) @db.Uuid
  paymentReference String            @unique @db.VarChar(100)
  loanId           String            @db.Uuid
  installmentId    String?           @db.Uuid
  userId           String            @db.Uuid
  amount           Decimal           @db.Decimal(15, 2)
  paymentMethod    PaymentMethod
  status           TransactionStatus @default(PENDING)
  gatewayReference String?           @db.VarChar(255)
  gatewayResponse  String?
  paymentDate      DateTime          @default(now()) @db.Timestamptz(3)
  confirmedAt      DateTime?         @db.Timestamptz(3)
  createdAt        DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(3)
  installment      Installment?      @relation(fields: [installmentId], references: [id])
  loan             Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction      Transaction?

  @@index([loanId])
  @@index([userId])
  @@index([status])
  @@index([paymentReference])
  @@index([paymentDate])
  @@map("payments")
}

model Disbursement {
  id                    String            @id @default(uuid()) @db.Uuid
  disbursementReference String            @unique @db.VarChar(100)
  loanId                String            @unique @db.Uuid
  schoolId              String            @db.Uuid
  amount                Decimal           @db.Decimal(15, 2)
  status                TransactionStatus @default(PENDING)
  bankName              String            @db.VarChar(100)
  accountNumber         String            @db.VarChar(20)
  accountName           String            @db.VarChar(255)
  transferReference     String?           @db.VarChar(255)
  transferResponse      String?
  disbursedAt           DateTime?         @db.Timestamptz(3)
  confirmedAt           DateTime?         @db.Timestamptz(3)
  createdAt             DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime          @updatedAt @db.Timestamptz(3)
  loan                  Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  school                SchoolProfile     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([schoolId])
  @@index([status])
  @@map("disbursements")
}

model LoanStatusHistory {
  id             String      @id @default(uuid()) @db.Uuid
  loanId         String      @db.Uuid
  previousStatus LoanStatus?
  newStatus      LoanStatus
  changedBy      String?     @db.Uuid
  reason         String?
  createdAt      DateTime    @default(now()) @db.Timestamptz(3)
  loan           Loan        @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([createdAt])
  @@map("loan_status_history")
}

// Add this new model to track verification activity logs
model VerificationLog {
  id             String             @id @default(uuid()) @db.Uuid
  verificationId String             @db.Uuid
  schoolId       String             @db.Uuid
  activity       String             @db.VarChar(255)
  details        String?
  status         VerificationStatus
  performedBy    String?            @db.Uuid
  createdAt      DateTime           @default(now()) @db.Timestamptz(3)
  verification   SchoolVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("verification_logs")
}

model SchoolVerification {
  id                  String             @id @default(uuid()) @db.Uuid
  loanId              String             @unique @db.Uuid
  schoolId            String             @db.Uuid
  studentName         String             @db.VarChar(255)
  studentClass        String             @db.VarChar(50)
  invoiceAmount       Decimal            @db.Decimal(15, 2)
  status              VerificationStatus @default(PENDING)
  enrollmentConfirmed Boolean            @default(false)
  invoiceConfirmed    Boolean            @default(false)
  actualInvoiceAmount Decimal?           @db.Decimal(15, 2)
  requestedAt         DateTime           @default(now()) @db.Timestamptz(3)
  respondedAt         DateTime?          @db.Timestamptz(3)
  verifiedBy          String?            @db.Uuid
  notes               String?
  createdAt           DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime           @updatedAt @db.Timestamptz(3)
  loan                Loan               @relation(fields: [loanId], references: [id], onDelete: Cascade)
  school              SchoolProfile      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  logs                VerificationLog[] // Add this relation

  @@index([loanId])
  @@index([schoolId])
  @@index([status])
  @@map("school_verifications")
}

model Document {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String?        @db.Uuid
  parentId     String?        @db.Uuid
  schoolId     String?        @db.Uuid
  loanId       String?        @db.Uuid
  documentType DocumentType
  fileName     String         @db.VarChar(255)
  fileUrl      String         @db.VarChar(500)
  fileSize     Int
  mimeType     String         @db.VarChar(100)
  isVerified   Boolean        @default(false)
  verifiedAt   DateTime?      @db.Timestamptz(3)
  verifiedBy   String?        @db.Uuid
  createdAt    DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime       @updatedAt @db.Timestamptz(3)
  loan         Loan?          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  parent       ParentProfile? @relation(fields: [parentId], references: [id], onDelete: Cascade)
  school       SchoolProfile? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentId])
  @@index([schoolId])
  @@index([loanId])
  @@index([documentType])
  @@map("documents")
}

model Wallet {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @unique @db.Uuid
  balance          Decimal       @default(0) @db.Decimal(15, 2)
  currency         String        @default("NGN") @db.VarChar(3)
  dailyLimit       Decimal?      @db.Decimal(15, 2)
  monthlyLimit     Decimal?      @db.Decimal(15, 2)
  autoDebitEnabled Boolean       @default(false)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @db.Timestamptz(3)
  transactions     Transaction[]
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

model Transaction {
  id                   String            @id @default(uuid()) @db.Uuid
  transactionReference String            @unique @db.VarChar(100)
  userId               String            @db.Uuid
  walletId             String?           @db.Uuid
  paymentId            String?           @unique @db.Uuid
  type                 TransactionType
  amount               Decimal           @db.Decimal(15, 2)
  balanceBefore        Decimal           @db.Decimal(15, 2)
  balanceAfter         Decimal           @db.Decimal(15, 2)
  description          String            @db.VarChar(500)
  category             String?           @db.VarChar(100)
  paymentMethod        PaymentMethod?
  status               TransactionStatus @default(PENDING)
  gatewayReference     String?           @db.VarChar(255)
  gatewayResponse      String?
  metadata             Json?
  transactionDate      DateTime          @default(now()) @db.Timestamptz(3)
  createdAt            DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime          @updatedAt @db.Timestamptz(3)
  payment              Payment?          @relation(fields: [paymentId], references: [id])
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet               Wallet?           @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([transactionReference])
  @@index([transactionDate])
  @@map("transactions")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String
  isRead    Boolean          @default(false)
  readAt    DateTime?        @db.Timestamptz(3)
  actionUrl String?          @db.VarChar(500)
  metadata  Json?
  createdAt DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt DateTime         @updatedAt @db.Timestamptz(3)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model EmailLog {
  id             String    @id @default(uuid()) @db.Uuid
  recipientEmail String    @db.VarChar(255)
  recipientName  String?   @db.VarChar(255)
  subject        String    @db.VarChar(500)
  body           String
  status         String    @default("pending") @db.VarChar(50)
  sentAt         DateTime? @db.Timestamptz(3)
  failedAt       DateTime? @db.Timestamptz(3)
  errorMessage   String?
  emailType      String    @db.VarChar(100)
  metadata       Json?
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)

  @@index([recipientEmail])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

model SmsLog {
  id               String    @id @default(uuid()) @db.Uuid
  recipientPhone   String    @db.VarChar(20)
  message          String
  status           String    @default("pending") @db.VarChar(50)
  sentAt           DateTime? @db.Timestamptz(3)
  failedAt         DateTime? @db.Timestamptz(3)
  errorMessage     String?
  gatewayReference String?   @db.VarChar(255)
  gatewayResponse  String?
  smsType          String    @db.VarChar(100)
  metadata         Json?
  createdAt        DateTime  @default(now()) @db.Timestamptz(3)

  @@index([recipientPhone])
  @@index([status])
  @@index([createdAt])
  @@map("sms_logs")
}

model SupportTicket {
  id           String                @id @default(uuid()) @db.Uuid
  ticketNumber String                @unique @db.VarChar(50)
  userId       String                @db.Uuid
  subject      String                @db.VarChar(500)
  category     String                @db.VarChar(100)
  priority     SupportTicketPriority @default(MEDIUM)
  status       SupportTicketStatus   @default(OPEN)
  description  String
  assignedTo   String?               @db.Uuid
  resolvedAt   DateTime?             @db.Timestamptz(3)
  closedAt     DateTime?             @db.Timestamptz(3)
  createdAt    DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime              @updatedAt @db.Timestamptz(3)
  attachments  SupportAttachment[]
  messages     SupportMessage[]
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([ticketNumber])
  @@map("support_tickets")
}

model SupportMessage {
  id         String        @id @default(uuid()) @db.Uuid
  ticketId   String        @db.Uuid
  senderId   String        @db.Uuid
  senderRole UserRole
  message    String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now()) @db.Timestamptz(3)
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}

model SupportAttachment {
  id        String        @id @default(uuid()) @db.Uuid
  ticketId  String        @db.Uuid
  fileName  String        @db.VarChar(255)
  fileUrl   String        @db.VarChar(500)
  fileSize  Int
  mimeType  String        @db.VarChar(100)
  createdAt DateTime      @default(now()) @db.Timestamptz(3)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_attachments")
}

model Faq {
  id        String   @id @default(uuid()) @db.Uuid
  question  String   @db.VarChar(500)
  answer    String
  category  String   @db.VarChar(100)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([category])
  @@index([isActive])
  @@map("faqs")
}

model Waitlist {
  id           String    @id @default(uuid()) @db.Uuid
  role         String    @db.VarChar(50)
  fullName     String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  phone        String    @db.VarChar(20)
  institution  String    @db.VarChar(255)
  loanAmount   String    @db.VarChar(50)
  status       String    @default("pending") @db.VarChar(50)
  invitedAt    DateTime? @db.Timestamptz(3)
  registeredAt DateTime? @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)

  @@index([email])
  @@index([status])
  @@map("waitlist")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @db.Uuid
  oldValues Json?
  newValues Json?
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       String
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@index([key])
  @@map("system_settings")
}

model PaymentReminder {
  id            String    @id @default(uuid()) @db.Uuid
  installmentId String    @db.Uuid
  reminderType  String    @db.VarChar(50)
  sentAt        DateTime? @db.Timestamptz(3)
  status        String    @default("pending") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)

  @@index([installmentId])
  @@index([status])
  @@map("payment_reminders")
}

model VerificationToken {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  token     String           @unique @db.VarChar(255)
  type      VerificationType
  expiresAt DateTime
  createdAt DateTime         @default(now()) @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// Add SchoolSupportMessage model for school-specific support
model SchoolSupportMessage {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @db.Uuid
  message   String
  priority  String    @default("normal") @db.VarChar(50) // normal, urgent
  isRead    Boolean   @default(false)
  readAt    DateTime? @db.Timestamptz(3)
  expiresAt DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)

  @@index([schoolId])
  @@index([isRead])
  @@index([createdAt])
  @@map("school_support_messages")
}


