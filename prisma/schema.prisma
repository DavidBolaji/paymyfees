generator client {
  provider = "prisma-client-js"
  // output          = "app/generated/prisma-client"
  // binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  email              String              @unique @db.VarChar(255)
  phone              String?             @unique @db.VarChar(20)
  password           String              @db.VarChar(255)
  role               UserRole
  fullName           String              @db.VarChar(255)
  profileImage       String?             @db.VarChar(500)
  emailVerified      Boolean             @default(false)
  phoneVerified      Boolean             @default(false)
  isActive           Boolean             @default(true)
  isFirstTime        Boolean             @default(true)
  lastLogin          DateTime?           @db.Timestamptz(3)
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)
  country            String              @db.VarChar(255)
  residencyStatus   ResidencyStatus      @default(LOCAL)
  auditLogs          AuditLog[]
  documents          Document[]
  loans              Loan[]
  notifications      Notification[]
  parentProfile      ParentProfile?
  payments           Payment[]
  schoolProfile      SchoolProfile[]
  supportTickets     SupportTicket[]
  transactions       Transaction[]
  wallet             Wallet?
  verificationTokens VerificationToken[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model ParentProfile {
  id                 String     @id @default(uuid()) @db.Uuid
  userId             String     @unique @db.Uuid
  dateOfBirth        DateTime?  @db.Date
  address            String?    @db.VarChar(500)
  city               String?    @db.VarChar(100)
  state              String?    @db.VarChar(100)
  country            String     @default("Nigeria") @db.VarChar(100)
  bvn                String?    @unique @db.VarChar(11)
  nin                String?    @unique @db.VarChar(11)
  bvnVerified        Boolean    @default(false)
  ninVerified        Boolean    @default(false)
  employmentStatus   String?    @db.VarChar(100)
  employerName       String?    @db.VarChar(255)
  monthlyIncome      Decimal?   @db.Decimal(15, 2)
  creditScore        Int?
  totalLoans         Int        @default(0)
  activeLoans        Int        @default(0)
  completedLoans     Int        @default(0)
  defaultedLoans     Int        @default(0)
  totalBorrowed      Decimal    @default(0) @db.Decimal(15, 2)
  totalRepaid        Decimal    @default(0) @db.Decimal(15, 2)
  outstandingBalance Decimal    @default(0) @db.Decimal(15, 2)
  createdAt          DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime   @updatedAt @db.Timestamptz(3)
  documents          Document[]
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  // children           Student[]

  @@index([bvn])
  @@index([nin])
  @@index([userId])
  @@map("parent_profiles")
}

model SchoolProfile {
  id                    String  @id @default(uuid()) @db.Uuid
  userId                String  @db.Uuid
  isPrimary             Boolean @default(false)
  schoolName            String  @db.VarChar(255)
  schoolAddress         String  @db.VarChar(500)
  city                  String? @db.VarChar(100)
  state                 String? @db.VarChar(100)
  country               String? @default("Nigeria") @db.VarChar(100)
  schoolEmail           String? @db.VarChar(255)
  schoolPhone           String? @db.VarChar(20)
  website               String? @db.VarChar(255)
  contactPersonName     String? @db.VarChar(255)
  contactPersonPosition String? @db.VarChar(100)
  contactPersonEmail    String? @db.VarChar(255)
  contactPersonPhone    String? @db.VarChar(20)
  bankName              String? @db.VarChar(100)
  accountNumber         String? @db.VarChar(20)
  accountName           String? @db.VarChar(255)

  academicLevel          String? @db.VarChar(100)
  currentAcademicSession String? @db.VarChar(50)
  notes                  String?

  isVerified           Boolean              @default(false)
  verifiedAt           DateTime?            @db.Timestamptz(3)
  totalStudents        Int                  @default(0)
  totalDisbursements   Decimal              @default(0) @db.Decimal(15, 2)
  createdAt            DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime             @updatedAt @db.Timestamptz(3)
  disbursements        Disbursement[]
  documents            Document[]
  loans                Loan[]
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationRequests SchoolVerification[]
  // students             Student[]

  @@index([schoolEmail])
  @@index([schoolPhone])
  @@index([userId])
  @@index([isVerified])
  @@map("school_profiles")
}

