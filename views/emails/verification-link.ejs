<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title><%= appName %> - Verify Your Email</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f3f6fb;
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
      font-family: Manrope, "Segoe UI", Arial, sans-serif;
    }
    table {
      border-spacing: 0;
      border-collapse: collapse;
    }
    .wrapper {
      width: 100%;
      background-color: #f3f6fb;
      padding: 24px 12px;
    }
    .card {
      width: 100%;
      max-width: 640px;
      background-color: #ffffff;
      border-radius: 18px;
      overflow: hidden;
      margin: 0 auto;
    }
    .header-image {
      display: block;
      width: 100%;
      height: auto;
    }
    .content {
      padding: 36px 42px 24px;
      color: #292929;
    }
    .heading {
      margin: 0 0 18px;
      font-family: Manrope, "Segoe UI", Arial, sans-serif;
      font-size: 22px;
      line-height: 120%;
      font-weight: 800;
      letter-spacing: 0;
      color: #292929;
      text-align: center;
    }
    .body {
      margin: 0 0 16px;
      font-family: Manrope, "Segoe UI", Arial, sans-serif;
      font-size: 18px;
      line-height: 120%;
      font-weight: 500;
      letter-spacing: 0;
      color: #292929;
    }
    .button-wrap {
      text-align: center;
      padding: 12px 0 16px;
    }
    .button {
      display: inline-block;
      background-color: #00296b;
      color: #ffffff !important;
      text-decoration: none;
      font-family: Manrope, "Segoe UI", Arial, sans-serif;
      font-size: 16px;
      line-height: 120%;
      font-weight: 700;
      letter-spacing: 0;
      padding: 14px 24px;
      border-radius: 10px;
    }
    .link-box {
      margin: 2px 0 18px;
      padding: 12px;
      border-radius: 10px;
      background-color: #edf2fa;
      word-break: break-word;
      font-family: Manrope, "Segoe UI", Arial, sans-serif;
      font-size: 14px;
      line-height: 135%;
      font-weight: 500;
      color: #00296b;
    }
    .footer {
      padding: 0 42px 30px;
      text-align: center;
      font-family: Manrope, "Segoe UI", Arial, sans-serif;
      font-size: 14px;
      line-height: 140%;
      font-weight: 500;
      color: #6c7480;
    }
    .footer p {
      margin: 0 0 8px;
    }
    @media only screen and (max-width: 640px) {
      .content,
      .footer {
        padding-left: 20px !important;
        padding-right: 20px !important;
      }
      .heading {
        font-size: 20px !important;
      }
      .body {
        font-size: 16px !important;
      }
    }
  </style>
</head>
<body>
  <table role="presentation" width="100%" class="wrapper">
    <tr>
      <td align="center">
        <table role="presentation" class="card" width="640">
          <tr>
            <td>
              <img
                src="https://res.cloudinary.com/dpi44zxlw/image/upload/v1772611742/header_hjx0ag.png"
                alt="<%= appName %>"
                class="header-image"
              >
            </td>
          </tr>
          <tr>
            <td class="content">
              <h1 class="heading">Verify Your Email Address</h1>
              <p class="body">Hi <%= fullName %>,</p>
              <p class="body">Click the button below to verify your email and activate your <%= appName %> account.</p>
              <div class="button-wrap">
                <a href="<%= verificationUrl %>" class="button">Verify Email Address</a>
              </div>
              <p class="body">If the button doesn’t work, use this secure link:</p>
              <div class="link-box"><%= verificationUrl %></div>
              <p class="body">This verification link expires in 24 hours.</p>
            </td>
          </tr>
          <tr>
            <td class="footer">
              <p>Need help? <a href="mailto:support@paymyfees.co" style="color: #00296b; text-decoration: none;">support@paymyfees.co</a></p>
              <p>© <%= new Date().getFullYear() %> <%= appName %>. All rights reserved.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>