<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
  <title>Loan Application Update</title>
  <style>
    body { margin:0; padding:0; background:#f3f6fb; font-family:'Manrope','Segoe UI',Arial,sans-serif; }
    .wrapper { width:100%; background:#f3f6fb; padding:24px 12px; }
    .card { border:2px solid #00296b; width:100%; max-width:640px; background:#fff; overflow:hidden; margin:0 auto; }
    .header { background:#00296b; padding:32px 42px 24px; }
    .header h1 { margin:0; color:#fff; font-size:22px; font-weight:800; }
    .content { padding:32px 42px 24px; color:#292929; }
    .badge { display:inline-block; background:#f8d7da; color:#721c24; font-size:13px; font-weight:700; padding:4px 12px; border-radius:20px; margin-bottom:16px; }
    .highlight { background:#fff3f3; border-left:4px solid #dc3545; padding:12px 16px; border-radius:6px; margin:18px 0; }
    .highlight p { margin:4px 0; font-size:15px; }
    .reason-box { background:#fafafa; border:1px solid #e0e0e0; border-radius:6px; padding:12px 16px; margin:14px 0; font-size:14px; color:#555; }
    .btn { display:inline-block; background:#00296b; color:#fff !important; text-decoration:none; font-size:15px; font-weight:700; padding:14px 28px; border-radius:10px; margin-top:18px; }
    .footer { padding:0 42px 28px; text-align:center; font-size:13px; color:#6c7480; }
    @media(max-width:640px){ .content,.footer{ padding-left:20px!important; padding-right:20px!important; } }
  </style>
</head>
<body>
  <table role="presentation" width="100%" class="wrapper"><tr><td align="center">
    <table role="presentation" class="card" width="640">
      <tr><td class="header">
        <h1><%= appName %></h1>
      </td></tr>
      <tr><td class="content">
        <span class="badge">Application Update</span>
        <h2 style="margin:0 0 12px;font-size:20px;color:#00296b;">Loan Application Update</h2>
        <p style="margin:0 0 12px;">Hi <strong><%= fullName %></strong>,</p>
        <p style="margin:0 0 16px;">Thank you for applying with us. After reviewing your application, we were unable to approve it at this time.</p>
        <div class="highlight">
          <p><strong>Loan Number:</strong> <%= loanNumber %></p>
          <p><strong>Status:</strong> Not Approved</p>
        </div>
        <% if (reason) { %>
        <p style="margin:12px 0 6px;font-weight:600;">Reason provided:</p>
        <div class="reason-box"><%= reason %></div>
        <% } %>
        <p style="margin:16px 0 0;">You may re-apply after addressing the reason above or contact our support team for more information.</p>
        <a href="<%= dashboardUrl %>" class="btn">Go to Dashboard</a>
      </td></tr>
      <tr><td class="footer">
        <p>© <%= new Date().getFullYear() %> <%= appName %>. All rights reserved.</p>
      </td></tr>
    </table>
  </td></tr></table>
</body>
</html>
